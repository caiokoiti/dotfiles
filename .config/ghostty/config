theme = dracula

background = 000000

background-opacity = 0.95
# background-blur = 20  # Disabled - causes significant performance issues

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

font-size = 15
font-family = JetBrainsMono Nerd Font Mono

confirm-close-surface = false
maximize = true
fullscreen = false

# comment?
window-height = 99999999
window-width = 99999999

# macos-titlebar-style = hidden

macos-icon-frame = beige
keybind = shift+enter=text:\x1b\r

# ── Zellij compatibility ─────────────────────────────────────────────────────
# Unbind Ghostty-native shortcuts that conflict with Zellij so they pass
# through to the terminal and Zellij can handle them.
keybind = ctrl+t=unbind          # Zellij: SwitchToMode "tab"
keybind = ctrl+n=unbind          # Zellij: SwitchToMode "resize"
keybind = ctrl+q=unbind          # Zellij: Quit
keybind = alt+left=unbind        # Zellij: MoveFocusOrTab "left"
keybind = alt+right=unbind       # Zellij: MoveFocusOrTab "right"
keybind = alt+up=unbind          # Zellij: MoveFocus "up"
keybind = alt+down=unbind        # Zellij: MoveFocus "down"
